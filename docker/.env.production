# Database
DATABASE_URL=postgresql://user:pass@postgres-host:5432/livestream

# Redis
REDIS_URL=redis://redis-host:6379

# NextAuth
AUTH_SECRET=your-random-secret-min-32-chars
AUTH_AUTHENTIK_ID=your-authentik-client-id
AUTH_AUTHENTIK_SECRET=your-authentik-client-secret
AUTH_AUTHENTIK_ISSUER=https://authentik.example.com/application/o/livestream

# SRS
SRS_API_URL=http://srs:1985
SRS_CALLBACK_SECRET=your-callback-secret

# Site
NEXT_PUBLIC_SITE_URL=https://live.example.com
